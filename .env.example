# MongoDB Connection
# Get your connection string from MongoDB Atlas or use a local MongoDB instance
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/goayachtworld"

# For local MongoDB:
# DATABASE_URL="mongodb://localhost:27017/goayachtworld"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here-generate-with-openssl-rand-base64-32"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
